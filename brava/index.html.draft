  <style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--slate:#1e2530;--gold:#c49a58;--gold-dark:#a0793d;--cream:#faf8f4;--cream-mid:#f0ebe1;--text:#2c2c2c}
body{font-family:'Inter',sans-serif;background:var(--cream);color:var(--text);line-height:1.7}
a{color:var(--gold-dark);text-decoration:none}
a:hover{text-decoration:underline}

/* NAVIGATION */
.nav{background:var(--slate);padding:18px 40px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.nav-logo{color:#fff;font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;letter-spacing:.04em;text-decoration:none}
.nav-logo:hover{text-decoration:none;color:var(--gold)}
.nav-links{display:flex;gap:32px;list-style:none}
.nav-links a{color:rgba(255,255,255,.82);font-size:14px;font-family:'Inter',sans-serif;letter-spacing:.04em;text-transform:uppercase;transition:color .2s}
.nav-links a:hover{color:var(--gold);text-decoration:none}
.nav-cta{background:var(--gold);color:var(--slate)!important;padding:10px 22px;border-radius:4px;font-weight:600;font-size:13px!important}
.nav-cta:hover{background:var(--gold-dark)!important}

/* HERO */
.hero{background:var(--slate);color:#fff;padding:80px 40px 72px}
.hero-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 420px;gap:72px;align-items:center}
.hero-eyebrow{font-family:'Inter',sans-serif;font-size:12px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
.hero h1{font-family:'Cormorant Garamond',serif;font-size:clamp(36px,5vw,58px);font-weight:700;line-height:1.1;margin-bottom:24px}
.hero h1 em{color:var(--gold);font-style:italic}
.hero-sub{font-size:17px;color:rgba(255,255,255,.78);margin-bottom:14px;line-height:1.7}
.hero-body{font-size:15px;color:rgba(255,255,255,.6);margin-bottom:36px;line-height:1.75}
.hero-phone{display:inline-flex;align-items:center;gap:12px;color:#fff;font-size:21px;font-family:'Cormorant Garamond',serif;font-weight:700;letter-spacing:.03em;text-decoration:none;border:1.5px solid rgba(196,154,88,.35);padding:14px 28px;border-radius:4px;transition:all .25s}
.hero-phone:hover{border-color:var(--gold);color:var(--gold);text-decoration:none}

/* LEAD FORM CARD */
.form-card{background:rgba(255,255,255,.05);border:1px solid rgba(196,154,88,.25);border-radius:6px;padding:32px 28px}
.form-card-eyebrow{font-family:'Inter',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:8px;display:block}
.form-card-title{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:#fff;margin-bottom:24px;line-height:1.25}
.form-group{margin-bottom:14px}
.form-label{display:block;font-size:11px;letter-spacing:.1em;text-transform:uppercase;color:rgba(255,255,255,.5);margin-bottom:6px;font-weight:500}
.form-input{width:100%;padding:12px 14px;background:rgba(255,255,255,.06);border:1px solid rgba(196,154,88,.2);color:#fff;font-family:'Inter',sans-serif;font-size:14px;outline:none;transition:border .25s;border-radius:3px}
.form-input::placeholder{color:rgba(255,255,255,.28)}
.form-input:focus{border-color:rgba(196,154,88,.6)}
select.form-input{appearance:none;-webkit-appearance:none;background-image:url('data:image/svg+xml;utf8,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2212%22 height=%2212%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23c49a58%22 stroke-width=%222%22><polyline points=%226 9 12 15 18 9%22/></svg>');background-repeat:no-repeat;background-position:right 14px center;background-size:12px;padding-right:36px;cursor:pointer}
select.form-input option{background:#1e2530}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-btn{width:100%;padding:15px;background:var(--gold);color:var(--slate);border:none;font-family:'Inter',sans-serif;font-size:14px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;cursor:pointer;transition:background .2s;border-radius:3px;margin-top:4px}
.form-btn:hover{background:var(--gold-dark)}
.form-btn:disabled{opacity:.65;cursor:not-allowed}
.form-note{font-size:12px;color:rgba(255,255,255,.32);text-align:center;margin-top:10px;line-height:1.5}

/* TRUST STRIP */
.trust-strip{background:#fff;border-bottom:1px solid #e8e2d9;padding:18px 40px;display:flex;justify-content:center;gap:48px;flex-wrap:wrap}
.trust-item{display:flex;align-items:center;gap:10px;font-size:13px;font-weight:600;letter-spacing:.04em;color:var(--slate);text-transform:uppercase}
.trust-dot{width:6px;height:6px;border-radius:50%;background:var(--gold);flex-shrink:0}

/* SECTIONS */
.section{padding:80px 40px}
.section-inner{max-width:1100px;margin:0 auto}
.section-label{font-family:'Inter',sans-serif;font-size:11px;letter-spacing:.18em;text-transform:uppercase;color:var(--gold);margin-bottom:16px;display:block}
.section-title{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,46px);font-weight:700;color:var(--slate);line-height:1.15;margin-bottom:24px}
.section-title em{color:var(--gold);font-style:italic}
.section-body{font-size:16px;line-height:1.85;color:#4a4a4a;max-width:780px;margin-bottom:18px}

/* CARDS */
.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(250px,1fr));gap:28px;margin-top:44px}
.card{background:#fff;border:1px solid #e8e2d9;border-top:3px solid var(--gold);padding:30px 26px;border-radius:4px}
.card h3{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--slate);margin-bottom:10px}
.card p{font-size:14px;line-height:1.8;color:#555}

/* PRODUCT TILES */
.product-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:28px;margin-top:44px}
.product-tile{background:#fff;border:1px solid #e8e2d9;border-radius:4px;overflow:hidden}
.product-img{height:220px;background:linear-gradient(135deg,#2e3744 0%,#1e2530 100%);display:flex;flex-direction:column;align-items:center;justify-content:center;position:relative;overflow:hidden}
.product-img img{width:100%;height:100%;object-fit:cover;display:block}
.product-placeholder{color:rgba(255,255,255,.22);font-family:'Inter',sans-serif;font-size:11px;letter-spacing:.12em;text-transform:uppercase;text-align:center;padding:20px;line-height:1.8}
.product-placeholder strong{display:block;font-size:13px;color:rgba(255,255,255,.4);margin-bottom:6px;font-family:'Cormorant Garamond',serif;font-weight:700;font-size:18px;letter-spacing:.04em}
.product-body{padding:26px}
.product-body h3{font-family:'Cormorant Garamond',serif;font-size:22px;font-weight:700;color:var(--slate);margin-bottom:10px}
.product-body p{font-size:14px;line-height:1.8;color:#555}

/* SPEC TABLE */
.spec-table{width:100%;border-collapse:collapse;margin-top:36px}
.spec-table th{background:var(--slate);color:#fff;padding:14px 18px;text-align:left;font-size:13px;letter-spacing:.06em;text-transform:uppercase}
.spec-table td{padding:14px 18px;font-size:14px;border-bottom:1px solid #e8e2d9}
.spec-table tr:nth-child(even) td{background:var(--cream-mid)}
.spec-table td:first-child{font-weight:600;color:var(--slate)}
.check{color:#2e7d32;font-weight:700}

/* PROCESS STEPS */
.process-steps{display:grid;grid-template-columns:repeat(3,1fr);gap:0;margin-top:44px}
.step{padding:30px 28px;border-left:1px solid #e8e2d9}
.step:nth-child(1),.step:nth-child(4){border-left:none}
.step:nth-child(4),.step:nth-child(5),.step:nth-child(6){border-top:1px solid #e8e2d9;padding-top:30px}
.step-number{font-family:'Cormorant Garamond',serif;font-size:52px;font-weight:700;color:rgba(196,154,88,.15);line-height:1;margin-bottom:14px}
.step h3{font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--slate);margin-bottom:8px}
.step p{font-size:14px;line-height:1.8;color:#555}

/* FAQ */
.faq-section{background:var(--cream-mid);padding:80px 40px}
.faq-inner{max-width:820px;margin:0 auto}
details{border:1px solid #ddd6ca;border-radius:4px;margin-bottom:14px;background:#fff;overflow:hidden}
details[open]{border-color:var(--gold)}
summary{padding:22px 28px;font-family:'Cormorant Garamond',serif;font-size:20px;font-weight:700;color:var(--slate);cursor:pointer;list-style:none;display:flex;justify-content:space-between;align-items:center}
summary::-webkit-details-marker{display:none}
summary::after{content:"+";font-size:22px;color:var(--gold);flex-shrink:0;margin-left:12px}
details[open] summary::after{content:"&#8722;"}
.faq-body{padding:0 28px 22px;font-size:15px;line-height:1.85;color:#4a4a4a}

/* CTA SECTION */
.cta-section{background:var(--slate);padding:90px 40px;text-align:center;color:#fff}
.cta-section h2{font-family:'Cormorant Garamond',serif;font-size:clamp(28px,4vw,46px);font-weight:700;margin-bottom:18px}
.cta-section h2 em{color:var(--gold);font-style:italic}
.cta-section p{font-size:16px;color:rgba(255,255,255,.72);max-width:560px;margin:0 auto 40px;line-height:1.8}
.btn-primary{display:inline-flex;align-items:center;gap:10px;background:var(--gold);color:var(--slate);padding:16px 32px;border-radius:4px;font-weight:700;font-size:15px;letter-spacing:.04em;transition:background .2s;text-decoration:none}
.btn-primary:hover{background:var(--gold-dark);text-decoration:none}
.btn-outline{display:inline-flex;align-items:center;gap:10px;background:transparent;color:#fff;padding:16px 32px;border-radius:4px;font-weight:600;font-size:15px;border:1.5px solid rgba(255,255,255,.3);margin-left:16px;transition:all .2s;text-decoration:none}
.btn-outline:hover{border-color:var(--gold);color:var(--gold);text-decoration:none}

/* CITIES */
.cities-strip{padding:50px 40px;background:#fff}
.cities-inner{max-width:1100px;margin:0 auto}
.cities-links{display:flex;flex-wrap:wrap;gap:10px;margin-top:20px}
.city-tag{background:var(--cream);border:1px solid #e0d9cc;padding:8px 16px;border-radius:3px;font-size:13px;font-weight:600;color:var(--slate);transition:all .2s;text-decoration:none}
.city-tag:hover{background:var(--gold);color:#fff;border-color:var(--gold);text-decoration:none}

/* FOOTER */
footer{background:var(--slate);color:rgba(255,255,255,.55);padding:40px;text-align:center;font-size:13px}
footer a{color:rgba(255,255,255,.55)}
footer a:hover{color:var(--gold)}
footer strong{color:#fff}

/* RESPONSIVE */
@media(max-width:960px){
  .hero-inner{grid-template-columns:1fr;gap:40px}
  .product-grid{grid-template-columns:1fr 1fr}
  .process-steps{grid-template-columns:1fr 1fr}
  .step:nth-child(2){border-left:1px solid #e8e2d9}
  .step:nth-child(3){border-top:1px solid #e8e2d9;padding-top:30px}
  .step:nth-child(4){border-left:none}
  .step:nth-child(odd){border-left:none}
  .step:nth-child(even){border-left:1px solid #e8e2d9}
}
@media(max-width:768px){
  .nav{padding:14px 20px}
  .nav-links{display:none}
  .hero{padding:56px 20px 48px}
  .section{padding:60px 20px}
  .faq-section{padding:60px 20px}
  .cta-section{padding:60px 20px}
  .trust-strip{padding:14px 20px;gap:18px}
  .cities-strip{padding:40px 20px}
  .form-row{grid-template-columns:1fr}
  .product-grid{grid-template-columns:1fr}
  .process-steps{grid-template-columns:1fr}
  .step{border-left:none!important;border-top:1px solid #e8e2d9;padding:24px 0}
  .step:first-child{border-top:none}
  .btn-outline{margin-left:0;margin-top:12px}
  .spec-table{font-size:13px}
  .spec-table th,.spec-table td{padding:10px 12px}
}
  </style>
</head>
